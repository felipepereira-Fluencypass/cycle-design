{
  "name": "cycle-design",
  "version": "0.1.0",
  "description": "Cycle Design — Design System da Fluencypass",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./icons": {
      "import": {
        "types": "./dist/icons.d.ts",
        "default": "./dist/icons.js"
      },
      "require": {
        "types": "./dist/icons.d.cts",
        "default": "./dist/icons.cjs"
      }
    },
    "./globals.css": "./src/globals.css",
    "./tokens": "./dist/tokens.css",
    "./styles.css": "./dist/styles.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/globals.css"
  ],
  "scripts": {
    "build": "tsup && npm run build:css",
    "build:css": "node scripts/build-css.mjs",
    "build:icons": "node scripts/build-icons.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint components/ src/",
    "lint:css": "stylelint 'components/**/*.css' 'tokens/**/*.css'",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish",
    "prepublishOnly": "npm run build",
    "size": "size-limit",
    "size:check": "size-limit --limit"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "25 kB",
      "name": "JS (components)"
    },
    {
      "path": "dist/styles.css",
      "limit": "15 kB",
      "name": "CSS (styles)"
    },
    {
      "path": "dist/tokens.css",
      "limit": "15 kB",
      "name": "CSS (tokens)"
    }
  ],
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@size-limit/file": "^12.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "glob": "^11.0.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "size-limit": "^12.0.1",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "svgo": "^3.3.0",
    "tsup": "^8.5.1",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felipepereira-Fluencypass/cycle-design.git"
  },
  "keywords": [
    "cycle-design",
    "design-system",
    "fluencypass",
    "react",
    "tokens"
  ],
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/felipepereira-Fluencypass/cycle-design/issues"
  },
  "homepage": "https://github.com/felipepereira-Fluencypass/cycle-design#readme",
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/cli": "^4.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0"
  }
}
